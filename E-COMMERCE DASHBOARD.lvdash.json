    {
      "name": "top_brands",
      "displayName": "Top 10 Brands by Revenue",
      "config": {
        "version": "1.1",
        "source": "SELECT \n  brand_name,\n  SUM(net_amount) as total_revenue\nFROM ecommerce.gold.fact_transactions_denorm GROUP BY brand_name ORDER BY total_revenue DESC LIMIT 10\n",
        "dimensions": [
          {
            "name": "brand_name",
            "expr": "brand_name",
            "displayName": "Brand Name"
          }
        ],
        "measures": [
          {
            "name": "revenue",
            "expr": "SUM(total_revenue)",
            "displayName": "Revenue"
          }
        ]
      }
    }
