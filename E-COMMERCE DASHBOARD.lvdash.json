              {
                "name": "main_query",
                "query": {
                  "datasetName": "77d21d08",
                  "fields": [
                    {
                      "name": "monthly(transaction_date)",
                      "expression": "DATE_TRUNC(\"MONTH\", `transaction_date`)"
                    },
                    {
                      "name": "sum(net_amount)",
                      "expression": "SUM(`net_amount`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "title": "Monthly Sales Trend",
                "showTitle": true
              },
              "widgetType": "line",
